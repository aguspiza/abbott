# Local model fallback (Ollama, LM Studio, etc.)
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=local
OPENAI_MODEL=llama3

TEAMS_WEBHOOK=https://outlook.office.com/webhook/...
